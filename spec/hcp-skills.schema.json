{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hcp.dev/spec/hcp-skills.schema.json",
  "title": "HCP Skill Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "hcp_version",
    "implementation",
    "transport_surfaces",
    "supported_constraints",
    "skills"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "hcp_version": {
      "type": "string",
      "minLength": 1
    },
    "implementation": {
      "$ref": "#/$defs/implementation"
    },
    "documentation_ref": {
      "type": "string",
      "minLength": 1
    },
    "security_contact": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "transport_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/transportSurface"
      }
    },
    "supported_constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "deployment_model",
        "authority_role"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "deployment_model": {
          "type": "string",
          "minLength": 1
        },
        "authority_role": {
          "type": "string",
          "minLength": 1
        },
        "vendor": {
          "type": "string",
          "minLength": 1
        },
        "runtime_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transportSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "description"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "http",
            "cli",
            "library",
            "tool"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        },
        "well_known_path": {
          "type": "string",
          "minLength": 1
        },
        "command_prefix": {
          "type": "string",
          "minLength": 1
        },
        "library_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "description",
        "input_schema_ref",
        "output_schema_ref",
        "transport_modes",
        "requires_authorization",
        "composite",
        "maps_to_operations"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^hcp\\.[a-z0-9_.]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "input_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "output_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "transport_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "http",
              "cli",
              "library",
              "tool"
            ]
          }
        },
        "requires_authorization": {
          "type": "boolean"
        },
        "composite": {
          "type": "boolean"
        },
        "maps_to_operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "capability_discovery",
              "authorization_request",
              "grant_retrieval",
              "runtime_binding_create",
              "runtime_binding_release",
              "grant_revocation",
              "audit_event_list",
              "context_injection"
            ]
          }
        },
        "accepted_hints": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_constraints": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "examples_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "listCapabilitiesInput": {
      "type": "object",
      "additionalProperties": true
    },
    "listCapabilitiesOutput": {
      "type": "object",
      "additionalProperties": true
    },
    "injectContextInput": {
      "type": "object",
      "additionalProperties": true
    },
    "injectContextOutput": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
